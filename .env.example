# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./wc2026.db

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
# Optional: previous key for graceful rotation (valid for one ACCESS_TOKEN_EXPIRE_MINUTES window)
SECRET_KEY_PREVIOUS=

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Football API ──────────────────────────────────────────────────────────────
# Get your key at https://rapidapi.com/api-sports/api/api-football
FOOTBALL_API_KEY=
# Use v3.football.api-sports.io for direct api-sports.io key (free tier)
# Use api-football-v3.p.rapidapi.com for a RapidAPI subscription
FOOTBALL_API_HOST=v3.football.api-sports.io
FOOTBALL_WC_LEAGUE_ID=1
FOOTBALL_WC_SEASON=2026

# ── CORS ─────────────────────────────────────────────────────────────────────
# JSON array of allowed frontend origins
CORS_ORIGINS=["http://localhost:5173"]

# ── Invites ───────────────────────────────────────────────────────────────────
INVITE_TOKEN_EXPIRE_HOURS=72

# ── Bootstrap admin (used ONCE on first startup if no admin exists) ───────────
FIRST_ADMIN_EMAIL=
FIRST_ADMIN_PASSWORD=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Frontend (build-time, Vite) ───────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
