# ── Database ─────────────────────────────────────────────────────────────────
# Use a descriptive filename to match your league, e.g. cl2025.db
DATABASE_URL=sqlite+aiosqlite:///./matchnights.db

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
# Optional: previous key for graceful rotation
SECRET_KEY_PREVIOUS=

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# False for local HTTP development. Change to True when running behind HTTPS in production.
COOKIE_SECURE=False

# ── Football data source ───────────────────────────────────────────────────────
# "football_data"  — football-data.org free API (default, includes WC 2026)
# "openfootball"   — free GitHub static JSON, no key required
# "api_sports"     — api-sports.io v3, paid plan required for 2026
FOOTBALL_DATA_SOURCE=football_data

# football-data.org free API key (https://www.football-data.org)
FOOTBALL_DATA_ORG_KEY=

# api-sports.io credentials (only needed when FOOTBALL_DATA_SOURCE=api_sports)
FOOTBALL_API_KEY=
FOOTBALL_API_HOST=v3.football.api-sports.io
FOOTBALL_WC_LEAGUE_ID=1
FOOTBALL_WC_SEASON=2026

# ── League display name ───────────────────────────────────────────────────────
# Shown in the downloaded .ics calendar name.
# Change this when tracking a different competition.
# Examples: "Champions League 2025", "Premier League 24/25", "Euro 2028"
LEAGUE_NAME=WC 2026

# ── CORS ─────────────────────────────────────────────────────────────────────
# JSON array of allowed frontend origins
CORS_ORIGINS=["http://localhost"]

# ── Invites ───────────────────────────────────────────────────────────────────
INVITE_TOKEN_EXPIRE_HOURS=72

# ── Bootstrap admin (used ONCE on first startup if no admin exists) ───────────
FIRST_ADMIN_EMAIL=
FIRST_ADMIN_PASSWORD=

# ── Odds ──────────────────────────────────────────────────────────────────────
# the-odds-api.com free key (500 requests/month)
# https://the-odds-api.com
ODDS_API_KEY=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
